# Normalize text files for cross-platform contributors.
* text=auto eol=lf

# Shell/scripts
*.sh text eol=lf
Makefile text eol=lf
Dockerfile text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.md text eol=lf
*.json text eol=lf
*.toml text eol=lf

# Binary artifacts
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.pdf binary
*.tar binary
*.gz binary
*.xz binary
