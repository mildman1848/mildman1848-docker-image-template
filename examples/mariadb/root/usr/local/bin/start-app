#!/usr/bin/env bash
set -euo pipefail

. /usr/local/bin/file-env

: "${MYSQL_DIR:=/config/databases}"
: "${MYSQL_DATABASE:=app}"
: "${MYSQL_USER:=app}"

sql_escape() {
  local value="$1"
  printf "%s" "${value//\'/\'\'}"
}

mkdir -p "$MYSQL_DIR" /run/mysqld /config/logs
chown -R abc:abc /config /run/mysqld

if [[ ! -d "$MYSQL_DIR/mysql" ]]; then
  echo "Initializing MariaDB data directory at $MYSQL_DIR"
  mariadb-install-db --user=abc --datadir="$MYSQL_DIR" --auth-root-authentication-method=normal

  echo "Starting temporary MariaDB for initial setup"
  s6-setuidgid abc mariadbd --datadir="$MYSQL_DIR" --socket=/run/mysqld/mysqld.sock --skip-networking &
  pid="$!"

  for _ in {1..60}; do
    if mariadb-admin --socket=/run/mysqld/mysqld.sock ping >/dev/null 2>&1; then
      break
    fi
    sleep 1
  done

  root_pw="${MYSQL_ROOT_PASSWORD:-}"
  app_pw="${MYSQL_PASSWORD:-}"
  escaped_root_pw="$(sql_escape "$root_pw")"
  escaped_app_pw="$(sql_escape "$app_pw")"

  if [[ -z "$root_pw" ]]; then
    echo "Warning: MYSQL_ROOT_PASSWORD is empty. Set FILE__MYSQL_ROOT_PASSWORD or MYSQL_ROOT_PASSWORD." >&2
  fi
  if [[ -z "$app_pw" ]]; then
    echo "Warning: MYSQL_PASSWORD is empty. Set FILE__MYSQL_PASSWORD or MYSQL_PASSWORD." >&2
  fi

  mariadb --socket=/run/mysqld/mysqld.sock <<SQL
DELETE FROM mysql.user WHERE User='';
CREATE DATABASE IF NOT EXISTS \`${MYSQL_DATABASE}\`;
CREATE USER IF NOT EXISTS '${MYSQL_USER}'@'%' IDENTIFIED BY '${escaped_app_pw}';
GRANT ALL PRIVILEGES ON \`${MYSQL_DATABASE}\`.* TO '${MYSQL_USER}'@'%';
ALTER USER 'root'@'localhost' IDENTIFIED BY '${escaped_root_pw}';
FLUSH PRIVILEGES;
SQL

  if [[ -n "$root_pw" ]]; then
    MYSQL_PWD="$root_pw" mariadb-admin --socket=/run/mysqld/mysqld.sock -uroot shutdown || kill "$pid"
  else
    mariadb-admin --socket=/run/mysqld/mysqld.sock -uroot shutdown || kill "$pid"
  fi
fi

exec s6-setuidgid abc mariadbd \
  --datadir="$MYSQL_DIR" \
  --bind-address=0.0.0.0 \
  --socket=/run/mysqld/mysqld.sock
